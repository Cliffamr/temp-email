# Environment Variables

# Database connection string (Vercel Postgres / Neon)
DATABASE_URL="postgresql://username:password@host:5432/database?sslmode=require"

# Comma-separated list of allowed email domains
ALLOWED_DOMAINS="example.com,mail.example.org"

# Webhook secret for HMAC signature verification (64 characters)
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET="your-64-character-secret-here-generate-with-openssl-rand-hex-32"

# Inbox TTL in hours (default: 24)
INBOX_TTL_HOURS="24"
